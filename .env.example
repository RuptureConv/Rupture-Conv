# URL publique canonique utilisée par les métadonnées, robots.txt et sitemap.xml.
NEXT_PUBLIC_SITE_URL=https://rupture-conv.fr

# Google Tag Manager. Le conteneur fourni est utilisé par défaut si cette variable est absente.
NEXT_PUBLIC_GTM_ID=GTM-P9XX929G

# Google Analytics 4. La propriété fournie est utilisée par défaut si cette variable est absente.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-HDDQ9CV6YQ

# Google AdSense est désactivé par défaut pour éviter les erreurs avant validation.
NEXT_PUBLIC_ENABLE_ADSENSE=false
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_BEFORE_SIMULATOR=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_CONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_AFTER_RESULT=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
